{
  "name": "cognusnet-core",
  "version": "0.1.0",
  "description": "Open source CognusNet core runtime for shared AI memory",
  "main": "dist/src/public/index.js",
  "types": "dist/src/public/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/public/index.d.ts",
      "require": "./dist/src/public/index.js",
      "default": "./dist/src/public/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "client": "tsx src/scripts/live-client.ts",
    "dev": "tsx watch src/index.ts",
    "mcp": "tsx src/scripts/mcp-server.ts",
    "verify:mcp": "tsx src/scripts/verify-mcp.ts",
    "prepare": "npm run build",
    "seed": "tsx src/scripts/seed.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fastify": "^5.2.1",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/pg": "^8.18.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
